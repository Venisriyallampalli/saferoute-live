# --- SafeRoute Live Mobile Configuration ---

# 1. Backend Connectivity
# Used to connect the mobile app to the Node.js backend (Auth, Sockets, Reports, AI)
# Set to auto to derive backend host from current Expo LAN host.
# You can still force a fixed URL by replacing auto with http://<ip>:3001
EXPO_PUBLIC_API_BASE_URL=auto

# 2. Map & Navigation Services (Mapbox)
# Used for Address Autocomplete (Search) and Reverse Geocoding (Address formatting)
# Ported from the original web application
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoibHlubnZpc2hhbnRoIiwiYSI6ImNtaGM3dDNhZTIwdWcya3BjMDlta2JzYjQifQ.xrN6-HYsxUE99AWH1mHBqQ

# 3. Google Maps Platform (Native Map Component)
# Used for the actual MapView display and marker rendering on Android/iOS
# Required APIs to enable: Maps SDK (Android/iOS), Directions API, Geocoding API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBwM1roefK1NyDGhIgodrsdiDZOBKI8hSM

# 4. Optional / Feature Specific
# Add any specialized service keys here (e.g., Firebase, Analytics)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=724794335326-e5gqlfsio3h98800eom3ce8hquknd5j0.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=724794335326-5trdrs151089giav4elqdsqsn22r8h83.apps.googleusercontent.com
