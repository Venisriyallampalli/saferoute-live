{
  "expo": {
    "name": "safe-route-mobile",
    "slug": "safe-route-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saferoutemobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.saferoute.live",
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyBwM1roefK1NyDGhIgodrsdiDZOBKI8hSM"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeRoute Live needs your location to show it on the map and for safety navigation.",
        "NSLocationAlwaysUsageDescription": "SafeRoute Live needs background location to keep live sharing active.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeRoute Live needs background location to keep live sharing active.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.saferoute.live",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBwM1roefK1NyDGhIgodrsdiDZOBKI8hSM"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
