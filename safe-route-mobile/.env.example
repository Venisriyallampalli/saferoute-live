# SafeRoute Live Mobile environment variables
# Copy this file to .env and fill with your own values.

# Backend API base URL
# Android emulator: http://10.0.2.2:3001
# iOS simulator: http://localhost:3001
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3001

# Mapbox token for directions + map tiles
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Google Maps API key for geocoding destination search
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBwM1roefK1NyDGhIgodrsdiDZOBKI8hSM

# Optional if backend already has WEATHER_API_KEY configured.
# Used by mobile to pass weather key to backend route scoring API.
EXPO_PUBLIC_WEATHER_API_KEY=c8a072b3f65d2ed152ca19107e6ae428
